# Admin Panel configuration. Copy to .env (loaded automatically) and edit.

# Port the API listens on.
PORT=4000

# Single admin password for the panel.
ADMIN_PASSWORD=admin

# Secret used to sign the session cookie (change in production).
COOKIE_SECRET=change-me-please

# OpenRouter API key injected into provisioned client configs.
# This stays on the server and is NEVER exposed to the browser.
OPENROUTER_API_KEY=

# Default model written into provisioned client configs.
DEFAULT_MODEL=openrouter/openai/gpt-4o-mini

# Root directory under which each client's isolated workspace lives.
WORKSPACES_ROOT=./data/workspaces
